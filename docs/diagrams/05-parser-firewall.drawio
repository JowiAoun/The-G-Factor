        <mxCell id="e_play_audio" style="edgeStyle=orthogonalEdgeStyle;rounded=1;flowAnimation=1;strokeColor=#FFD24A;strokeWidth=2.5;endArrow=block;html=1;" edge="1" parent="lyr_edges" source="play" target="audio">
          <mxGeometry relative="1" as="geometry" />
