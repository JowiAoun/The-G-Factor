        <mxCell id="e_fail" value="syntax or unsafe" style="edgeStyle=orthogonalEdgeStyle;rounded=1;flowAnimation=1;strokeColor=#FF4D4D;strokeWidth=2.5;endArrow=block;html=1;fontColor=#FFD9D9;fontStyle=1;" edge="1" parent="lyr_edges" source="decision" target="retry">
