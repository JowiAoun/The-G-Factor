<mxfile host="app.diagrams.net" agent="the-g-factor-blog" version="24.0.0">
  <diagram name="Parser firewall zoom" id="parser-firewall">
    <mxGraphModel dx="1000" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1240" pageHeight="980" math="0" shadow="0" background="#141021">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="lyr_title" value="Title" parent="0" />
        <mxCell id="lyr_flow" value="Checks" parent="0" />
