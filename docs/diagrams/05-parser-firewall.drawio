        <mxCell id="e23" style="edgeStyle=orthogonalEdgeStyle;rounded=1;flowAnimation=1;strokeColor=#19E0FF;strokeWidth=2.5;endArrow=block;html=1;" edge="1" parent="lyr_edges" source="s2" target="s3">
          <mxGeometry relative="1" as="geometry" />
