        <mxCell id="e_retry_loop" value="next attempt re-enters here" style="edgeStyle=orthogonalEdgeStyle;rounded=1;dashed=1;strokeColor=#FF4D4D;strokeWidth=2;endArrow=block;html=1;fontColor=#FFD9D9;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="lyr_edges" source="retry" target="s2">
