        <mxCell id="lyr_retry" value="Retry path" parent="0" />
        <mxCell id="lyr_panel" value="Reference panels" parent="0" />
        <mxCell id="lyr_edges" value="Flows" parent="0" />

        <mxCell id="title" value="Layer 3 zoom - the parser firewall" style="text;html=1;fontColor=#3DDC84;fontSize=26;fontStyle=1;align=left;verticalAlign=middle;" vertex="1" parent="lyr_title">
          <mxGeometry x="40" y="22" width="680" height="40" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="src/strudel/parse.ts - two stages, plus a 3-attempt retry. Broken syntax never reaches the UI." style="text;html=1;fontColor=#C9B8FF;fontSize=14;align=left;verticalAlign=middle;" vertex="1" parent="lyr_title">
          <mxGeometry x="40" y="60" width="900" height="24" as="geometry" />
        </mxCell>

        <mxCell id="s1" value="Raw model output&#10;(a JSON string)" style="rounded=1;arcSize=12;fillColor=#2e1322;strokeColor=#FF3D7F;strokeWidth=2;fontColor=#FFD9EA;fontSize=13;fontStyle=1;whiteSpace=wrap;html=1;verticalAlign=middle;align=center;" vertex="1" parent="lyr_flow">
          <mxGeometry x="420" y="110" width="280" height="70" as="geometry" />
        </mxCell>
        <mxCell id="s2" value="Stage 0 - extract JSON + zod schema&#10;safeParseVariation() / safeParseTurn()&#10;requires new_mix_code and friends" style="rounded=1;arcSize=12;fillColor=#06262e;strokeColor=#19E0FF;strokeWidth=2;fontColor=#CFF7FF;fontSize=12;whiteSpace=wrap;html=1;verticalAlign=middle;align=center;" vertex="1" parent="lyr_flow">
          <mxGeometry x="420" y="220" width="280" height="90" as="geometry" />
        </mxCell>
        <mxCell id="s3" value="Stage 1 - acorn.parse&#10;ecmaVersion 2022&#10;is it even valid JS?" style="rounded=1;arcSize=12;fillColor=#13251a;strokeColor=#3DDC84;strokeWidth=2;fontColor=#CFFBE2;fontSize=12;whiteSpace=wrap;html=1;verticalAlign=middle;align=center;" vertex="1" parent="lyr_flow">
          <mxGeometry x="420" y="350" width="280" height="80" as="geometry" />
        </mxCell>
        <mxCell id="s4" value="Stage 2 - acorn-walk AST security pass&#10;deny-list walk over every node" style="rounded=1;arcSize=12;fillColor=#13251a;strokeColor=#3DDC84;strokeWidth=2;fontColor=#CFFBE2;fontSize=12;whiteSpace=wrap;html=1;verticalAlign=middle;align=center;" vertex="1" parent="lyr_flow">
          <mxGeometry x="420" y="470" width="280" height="80" as="geometry" />
        </mxCell>
        <mxCell id="decision" value="valid?" style="rhombus;fillColor=#241a33;strokeColor=#C9B8FF;strokeWidth=2;fontColor=#EADFFF;fontSize=15;fontStyle=1;whiteSpace=wrap;html=1;" vertex="1" parent="lyr_flow">
          <mxGeometry x="430" y="590" width="260" height="110" as="geometry" />
        </mxCell>

        <mxCell id="play" value="play()&#10;src/strudel/engine.ts" style="rounded=1;arcSize=12;fillColor=#3a2a08;strokeColor=#FFD24A;strokeWidth=2;fontColor=#FFE9A8;fontSize=13;fontStyle=1;whiteSpace=wrap;html=1;verticalAlign=middle;align=center;" vertex="1" parent="lyr_decision">
          <mxGeometry x="420" y="750" width="280" height="60" as="geometry" />
        </mxCell>
        <mxCell id="audio" value="globalThis.evaluate() then audio" style="rounded=1;arcSize=12;fillColor=#3a2a08;strokeColor=#FFD24A;strokeWidth=2;fontColor=#FFE9A8;fontSize=13;fontStyle=1;whiteSpace=wrap;html=1;verticalAlign=middle;align=center;" vertex="1" parent="lyr_decision">
          <mxGeometry x="420" y="850" width="280" height="60" as="geometry" />
        </mxCell>

        <mxCell id="retry" value="Fail: retry with a 'why it failed' hint&#10;MAX_RETRIES = 3, temperature climbs each try" style="rounded=1;arcSize=12;fillColor=#2e1414;strokeColor=#FF4D4D;strokeWidth=2;fontColor=#FFD9D9;fontSize=12;fontStyle=1;whiteSpace=wrap;html=1;verticalAlign=middle;align=center;" vertex="1" parent="lyr_retry">
          <mxGeometry x="760" y="560" width="400" height="80" as="geometry" />
        </mxCell>
        <mxCell id="after3" value="After 3 fails: surface a visible error&#10;broken code never reaches the UI" style="rounded=1;arcSize=12;fillColor=#2e1414;strokeColor=#FF4D4D;strokeWidth=2;fontColor=#FFD9D9;fontSize=12;fontStyle=1;whiteSpace=wrap;html=1;verticalAlign=middle;align=center;" vertex="1" parent="lyr_retry">
          <mxGeometry x="760" y="680" width="400" height="70" as="geometry" />
        </mxCell>

        <mxCell id="panel" value="Rejected by the AST security pass&#10;&#10;41 banned globals across 7 groups:&#10;  network - fetch, XMLHttpRequest, WebSocket, navigator&#10;  window/document - window, document, location, history&#10;  storage - localStorage, sessionStorage, indexedDB, caches&#10;  workers/IPC - Worker, postMessage, Atomics, SharedArrayBuffer&#10;  dynamic eval - eval, Function&#10;  timing - setTimeout, setInterval, requestAnimationFrame&#10;  sensitive - crypto, clipboard&#10;&#10;6 sandbox-escape members:&#10;  .constructor  .__proto__  .prototype&#10;  .cookie  .innerHTML  .outerHTML&#10;&#10;plus: reject import() and import.meta" style="rounded=1;arcSize=4;fillColor=#181226;strokeColor=#5a4b86;strokeWidth=1;fontColor=#D8C9FF;fontSize=11;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;whiteSpace=wrap;html=1;" vertex="1" parent="lyr_panel">
          <mxGeometry x="760" y="110" width="400" height="330" as="geometry" />
        </mxCell>
        <mxCell id="secondnet" value="Second net: a runtime try/catch around evaluate() in src/strudel/engine.ts catches mini-notation that parses fine but throws when it actually runs - those surface as visible errors instead of silent failures." style="rounded=1;arcSize=8;fillColor=#10222b;strokeColor=#19E0FF;strokeWidth=2;fontColor=#CFF7FF;fontSize=12;fontStyle=2;align=left;verticalAlign=middle;spacingLeft=12;whiteSpace=wrap;html=1;" vertex="1" parent="lyr_panel">
          <mxGeometry x="760" y="790" width="400" height="130" as="geometry" />
        </mxCell>

        <mxCell id="e12" style="edgeStyle=orthogonalEdgeStyle;rounded=1;flowAnimation=1;strokeColor=#19E0FF;strokeWidth=2.5;endArrow=block;html=1;" edge="1" parent="lyr_edges" source="s1" target="s2">
