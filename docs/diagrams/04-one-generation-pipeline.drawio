        <mxCell id="s1" value="1. User action&#10;&#10;pick a seed or&#10;send a chat turn" style="rounded=1;arcSize=12;fillColor=#3a2a08;strokeColor=#FFD24A;strokeWidth=2;fontColor=#FFE9A8;fontSize=13;fontStyle=1;whiteSpace=wrap;html=1;verticalAlign=middle;align=center;" vertex="1" parent="lyr_s1">
          <mxGeometry x="40" y="280" width="220" height="130" as="geometry" />
        </mxCell>
        <mxCell id="s2" value="2. Retrieve taste&#10;&#10;getTopKSimilar(seed, 3)&#10;src/memory/taste.ts" style="rounded=1;arcSize=12;fillColor=#06262e;strokeColor=#19E0FF;strokeWidth=2;fontColor=#CFF7FF;fontSize=13;fontStyle=1;whiteSpace=wrap;html=1;verticalAlign=middle;align=center;" vertex="1" parent="lyr_s2">
          <mxGeometry x="300" y="280" width="220" height="130" as="geometry" />
