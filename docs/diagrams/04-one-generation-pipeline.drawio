        <mxCell id="s3" value="3. Assemble prompt&#10;&#10;priors + top-3 exemplars&#10;+ axis directive&#10;src/model/prompts.ts" style="rounded=1;arcSize=12;fillColor=#241a33;strokeColor=#C9B8FF;strokeWidth=2;fontColor=#EADFFF;fontSize=13;fontStyle=1;whiteSpace=wrap;html=1;verticalAlign=middle;align=center;" vertex="1" parent="lyr_s3">
          <mxGeometry x="560" y="280" width="220" height="130" as="geometry" />
        </mxCell>
        <mxCell id="s4" value="4. Generate&#10;&#10;generate() - src/model/gemma.ts&#10;local: serial 1500 ms&#10;remote: fan-out 0 ms&#10;src/model/backend.ts" style="rounded=1;arcSize=12;fillColor=#2e1322;strokeColor=#FF3D7F;strokeWidth=2;fontColor=#FFD9EA;fontSize=13;fontStyle=1;whiteSpace=wrap;html=1;verticalAlign=middle;align=center;" vertex="1" parent="lyr_s4">
          <mxGeometry x="820" y="280" width="220" height="130" as="geometry" />
